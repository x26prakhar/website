---
import BaseLayout from '../layouts/BaseLayout.astro';

const projects = [
  {
    name: "Made in Bharat",
    subtitle: "The Quiet Entrepreneurial Revolution",
    platform: "Podcast · Spotify",
    description: "Conversations with founders building in tier 2 and tier 3 towns and the remotest parts of India. Stories of resilience, innovation, and businesses that are reshaping the Indian entrepreneurial landscape.",
    url: "https://open.spotify.com/show/0Sy5mrYRx5bLik5uBziLTF?si=4SWwHf8yTMegEFhNjCIGmA&nd=1&dlsi=f20913e4698e49a5",
    cta: "Listen →",
    image: "/images/made-in-bharat.png",
    color: { label: "#3b2d5c" },
  },
  {
    name: "prakhar.vc",
    subtitle: "@prakhar.vc",
    platform: "Instagram",
    description: "Notes and observations on venture, impact, and ideas from the field.",
    url: "https://www.instagram.com/prakhar.vc/",
    cta: "Follow →",
    image: null,
    color: { label: "#6b2d3a" },
  },
  {
    name: "AI for Non-Techies",
    subtitle: "aifornontechies.substack.com",
    platform: "Newsletter · Substack",
    description: "Making sense of AI for people who didn't study computer science.",
    url: "https://aifornontechies.substack.com/",
    cta: "Subscribe →",
    image: "/images/aifornontechies.png",
    color: { label: "#1a3a8a" },
  },
];

const igGradient = "linear-gradient(135deg, #f9ce34, #ee2a7b, #6228d7)";
---

<BaseLayout title="Creative Projects — Prakhar Singh">
  <section class="cp-section">
    <div class="cp-container">
      <div class="cp-grid">
        {projects.map((p) => (
          <a href={p.url} target="_blank" rel="noopener noreferrer" class="cp-card">
            <div class="cp-image-wrap">
              {p.image ? (
                <img src={p.image} alt={p.name} class="cp-image" />
              ) : (
                <div class="cp-ig-thumb" style={`background: ${igGradient};`}>
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="white" width="56" height="56"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
                </div>
              )}
            </div>
            <div class="cp-card-body">
              <h2 class="cp-name">{p.name}</h2>
              <span class="cp-subtitle">{p.subtitle}</span>
              <span class="cp-platform">{p.platform}</span>
              <p class="cp-desc">{p.description}</p>
            </div>
            <div class="cp-card-footer">
              <span class="cp-cta">{p.cta}</span>
            </div>
          </a>
        ))}
      </div>
    </div>

    <div class="wa-callout-wrap">
      <a href="https://chat.whatsapp.com/GIkUd2Zd5425GzfRpmHyHR" target="_blank" rel="noopener noreferrer" class="wa-callout">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        <span>I run a WhatsApp community on AI for non-techies.</span>
        <span class="wa-members">500+ members</span>
        <span class="wa-join">Join →</span>
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  .cp-section {
    padding: 48px 0 80px;
  }

  .cp-container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .cp-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    column-gap: 20px;
    row-gap: 0;
  }

  .cp-card {
    display: flex;
    flex-direction: column;
    background: var(--color-card-bg);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    text-decoration: none;
    color: inherit;
    overflow: hidden;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
    margin-bottom: 20px;
  }

  .cp-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
    text-decoration: none;
  }

  .cp-image-wrap {
    width: 100%;
    height: 260px;
    overflow: hidden;
    flex-shrink: 0;
    background: var(--color-card-bg);
    padding: 8px;
    box-sizing: border-box;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .cp-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    border-radius: 2px;
  }

  .cp-ig-thumb {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 2px;
  }

  .cp-card-body {
    padding: 18px 22px 12px;
    display: flex;
    flex-direction: column;
    gap: 4px;
    flex: 1;
  }

  .cp-name {
    font-family: var(--font-body);
    font-size: 0.95rem;
    font-weight: 600;
    line-height: 1.3;
    color: var(--color-text);
    margin: 0;
  }

  .cp-subtitle {
    font-size: 0.75rem;
    color: var(--color-text-secondary);
    font-style: italic;
  }

  .cp-platform {
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--color-text-secondary);
    opacity: 0.6;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: 6px;
  }

  .cp-desc {
    font-size: 0.83rem;
    color: var(--color-text-secondary);
    line-height: 1.65;
    margin: 0;
  }

  .cp-card-footer {
    padding: 12px 22px 16px;
    display: flex;
    justify-content: flex-end;
    align-items: center;
    border-top: 1px solid var(--color-border);
  }

  .cp-cta {
    font-size: 0.78rem;
    color: var(--color-accent);
    font-weight: 600;
  }

  /* WhatsApp callout */
  .wa-callout-wrap {
    display: flex;
    justify-content: center;
    margin-top: 12px;
    padding-bottom: 16px;
  }

  .wa-callout {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: #e8f5e2;
    border: 1px solid #c3ddb8;
    border-radius: 4px;
    padding: 13px 22px;
    font-size: 0.85rem;
    color: #2d5a20;
    text-decoration: none;
    transition: background 0.15s ease;
  }

  .wa-callout:hover {
    background: #ddf0d4;
    text-decoration: none;
  }

  .wa-members {
    background: #c3ddb8;
    color: #2d5a20;
    font-size: 0.72rem;
    font-weight: 600;
    padding: 2px 8px;
    border-radius: 20px;
  }

  .wa-join {
    font-weight: 600;
    margin-left: 4px;
  }

  @media (max-width: 900px) {
    .cp-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 560px) {
    .cp-grid {
      grid-template-columns: 1fr;
    }

    .cp-section {
      padding-top: 24px;
    }

    .wa-callout {
      flex-wrap: wrap;
      gap: 8px;
      justify-content: center;
    }
  }
</style>
