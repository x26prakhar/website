---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('posts');
const sortedPosts = posts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime()).slice(0, 3);

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<BaseLayout title="Prakhar Singh">
    <!-- Hero Section -->
    <section class="hero">
        <div class="container">
            <h1 class="hero-greeting">Hello, I'm Prakhar.</h1>
        </div>
    </section>

    <!-- About Section -->
    <section class="about">
        <div class="container">
            <p>
                Currently, I'm at <a href="https://www.iima.ac.in/" target="_blank" rel="noopener">IIM Ahmedabad</a> pursuing the MBA (PGPX). Before this, I spent a few years in venture capital at <a href="https://enzia.vc" target="_blank" rel="noopener">Enzia Ventures</a>, and earlier at <a href="https://www.yunussocialbusiness.com/" target="_blank" rel="noopener">Yunus Social Business</a>, working closely with founders building in education, healthcare, rural development, and livelihoods. What drew me in was simple. I like being close to people who are trying to solve hard, real problems.
            </p>
            <p>
                I started out in economics and public policy. At <a href="https://prsindia.org/" target="_blank" rel="noopener">PRS Legislative Research</a>, I was a <a href="https://prsindia.org/lamp" target="_blank" rel="noopener">LAMP Fellow</a>, working with Members of Parliament on research and legislative work. It gave me a front row seat to how decisions are made, and how much better they can be with the right inputs. I had the chance to work with some incredible leaders, including the Deputy Chief Minister of Haryana and one of the youngest MPs in the country. That experience shaped how I think about systems, incentives, and impact.
            </p>
            <p>
                Post that, I joined <a href="https://www.theconvergencefoundation.org/" target="_blank" rel="noopener">The Convergence Foundation</a>, where I worked across education and philanthropy. I was part of the early team building <a href="https://www.indianphilanthropy.org/" target="_blank" rel="noopener">Accelerate Indian Philanthropy</a> and <a href="https://www.centralsquarefoundation.org/" target="_blank" rel="noopener">Central Square Foundation</a>, which were attempts to think more seriously about how capital can be deployed for public good.
            </p>
            <p>
                I read a lot, write often, and enjoy exploring ideas across economics, policy, and technology. I'm drawn to conversations that challenge how I think, and I like going deep on questions that matter.
            </p>

            <p class="contact-links">
                <a href="https://www.linkedin.com/in/prakharsingh96/" target="_blank" rel="noopener">LinkedIn</a>
                <span class="contact-sep">·</span>
                <a href="mailto:prakhar.lamp@gmail.com">prakhar.lamp@gmail.com</a>
                <span class="contact-sep">·</span>
                <a href="https://www.instagram.com/prakhar.vc/" target="_blank" rel="noopener">Instagram</a>
            </p>

            <div class="wa-callout-wrap">
              <a href="https://chat.whatsapp.com/GIkUd2Zd5425GzfRpmHyHR" target="_blank" rel="noopener noreferrer" class="wa-callout">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                <span>I run a WhatsApp community on AI for non-techies.</span>
                <span class="wa-members">500+ members</span>
                <span class="wa-join">Join →</span>
              </a>
            </div>
        </div>
    </section>

</BaseLayout>

<style>
  .contact-links {
    font-size: 0.9rem !important;
  }

  .contact-sep {
    color: var(--color-text-secondary);
    margin: 0 10px;
  }

  /* WhatsApp callout */
  .wa-callout-wrap {
    display: flex;
    justify-content: flex-start;
    margin-top: 0;
  }

  .wa-callout {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: #e8f5e2;
    border: 1px solid #c3ddb8;
    border-radius: 4px;
    padding: 13px 22px;
    font-size: 0.85rem;
    color: #2d5a20;
    text-decoration: none;
    transition: background 0.15s ease;
  }

  .wa-callout:hover {
    background: #ddf0d4;
    text-decoration: none;
  }

  .wa-members {
    background: #c3ddb8;
    color: #2d5a20;
    font-size: 0.72rem;
    font-weight: 600;
    padding: 2px 8px;
    border-radius: 20px;
  }

  .wa-join {
    font-weight: 600;
    margin-left: 4px;
  }

  @media (max-width: 560px) {
    .wa-callout {
      flex-wrap: wrap;
      gap: 8px;
    }
  }
</style>
