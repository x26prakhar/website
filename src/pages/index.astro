---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('posts');
const sortedPosts = posts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime()).slice(0, 3);

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<BaseLayout title="Prakhar Singh - VC at Enzia Ventures | Climate, Health, Education">
    <!-- Hero Section -->
    <section class="hero">
        <div class="container">
            <h1 class="hero-greeting">Hello, I'm Prakhar Singh.</h1>
        </div>
    </section>

    <!-- About Section -->
    <section class="about">
        <div class="container">
            <p>
                I'm a VC at <a href="https://enzia.vc" target="_blank">Enzia Ventures</a>, investing in founders building for Climate, Health, and Education. I spend my days meeting exceptional entrepreneurs solving India's most pressing challenges.
            </p>
            <p>
                Previously, I was at <a href="https://www.intuyusocialbusiness.com/" target="_blank">Yunus Social Business</a> (Portfolio Associate), <a href="https://www.intuyusocialbusiness.com/" target="_blank">The Convergence Foundation</a> (founding employee at Accelerate Indian Philanthropy & Central Square Foundation), and <a href="https://prsindia.org/lamp" target="_blank">PRS Legislative Research</a> (LAMP Fellow).
            </p>
            <p>
                I write a monthly newsletter called <a href="https://www.linkedin.com/newsletters/the-elusive-impact-6973936476893241344/" target="_blank">The Elusive Impact</a> covering economics, public policy, and impact investing. My writing has appeared in Mint, Telegraph, Economic & Political Weekly, and Times of India.
            </p>
            <p>
                If you're building in Healthcare, Agritech, Waste Management, or Circularity, feel free to reach out at <a href="mailto:prakhar.singh@enzia.vc">prakhar.singh@enzia.vc</a>. You can also find me on <a href="https://linkedin.com/in/prakharsingh" target="_blank" rel="noopener">LinkedIn</a> and <a href="https://twitter.com/prakharsingh" target="_blank" rel="noopener">Twitter</a>.
            </p>
        </div>
    </section>

</BaseLayout>
