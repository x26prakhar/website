---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "VC at Enzia Ventures investing in Climate, Health, and Education. Writing about economics, public policy, and impact investing." } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <meta name="description" content={description}>
    <meta property="og:title" content={title}>
    <meta property="og:description" content={description}>
    <meta property="og:type" content="website">
    <meta name="twitter:card" content="summary_large_image">
</head>
<body>
    <nav class="navbar">
        <ul class="nav-links">
            <li><a href="/">About Me</a></li>
            <li class="nav-dropdown">
              <span class="nav-dropdown-label">Writing</span>
              <ul class="nav-dropdown-menu">
                <li><a href="/publications">Commissioned Work</a></li>
                <li><a href="/blog">Blog</a></li>
              </ul>
            </li>
            <li><a href="/ai-experiments">AI Experiments</a></li>
            <li><a href="/creative-projects">Creative Projects</a></li>
        </ul>
    </nav>

    <slot />

    <footer class="footer">
        <div class="container">
            <p>&copy; 2026 Prakhar Singh. All rights reserved.</p>
        </div>
    </footer>

</body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>

<style>
  .nav-dropdown {
    position: relative;
  }

  .nav-dropdown-label {
    font-family: var(--font-display);
    font-size: 1.2rem;
    color: var(--color-text);
    cursor: pointer;
    transition: color 0.2s ease;
  }

  .nav-dropdown:hover .nav-dropdown-label {
    color: var(--color-accent);
  }

  .nav-dropdown-menu {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    transform: none;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    list-style: none;
    padding: 10px 0 6px;
    min-width: 170px;
    z-index: 100;
    box-shadow: 0 4px 16px rgba(0,0,0,0.07);
    flex-direction: column;
    align-items: stretch;
    gap: 0;
  }

  .nav-dropdown:hover .nav-dropdown-menu {
    display: flex;
  }

  /* Reset global nav-links li styles for dropdown items */
  .nav-dropdown-menu li {
    display: block !important;
    align-items: unset;
  }

  .nav-dropdown-menu li::after {
    display: none !important;
  }

  .nav-dropdown-menu li a {
    display: block;
    padding: 8px 18px;
    font-family: var(--font-display);
    font-size: 1.1rem;
    color: var(--color-text);
    text-decoration: none;
    white-space: nowrap;
    transition: color 0.15s ease;
    text-align: left;
  }

  .nav-dropdown-menu li a:hover {
    color: var(--color-accent);
  }

  @media (max-width: 640px) {
    .nav-dropdown-label {
      font-size: 1rem;
    }
  }

  @media (max-width: 400px) {
    .nav-dropdown-label {
      font-size: 0.95rem;
    }
  }
</style>
